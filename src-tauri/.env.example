# Copy this file to src-tauri/.env if you need to override any defaults.
# Everything here is optional - the app talks to a local llama-server on
# http://localhost:8080 out of the box, no key required.

# LOCAL_LLM_BASE_URL=http://localhost:8080
# LOCAL_LLM_MODEL=local-model
# Only needed if you started llama-server with --api-key:
# LOCAL_LLM_API_KEY=
